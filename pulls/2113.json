      "html_url": "https://github.com/schjonhaug",
      "followers_url": "https://api.github.com/users/schjonhaug/followers",
      "following_url": "https://api.github.com/users/schjonhaug/following%7B/other_user%7D",
      "gists_url": "https://api.github.com/users/schjonhaug/gists%7B/gist_id%7D",
      "starred_url": "https://api.github.com/users/schjonhaug/starred%7B/owner%7D%7B/repo%7D",
      "subscriptions_url": "https://api.github.com/users/schjonhaug/subscriptions",
      "organizations_url": "https://api.github.com/users/schjonhaug/orgs",
      "repos_url": "https://api.github.com/users/schjonhaug/repos",
      "events_url": "https://api.github.com/users/schjonhaug/events%7B/privacy%7D",

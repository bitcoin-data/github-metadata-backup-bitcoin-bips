    "title": "BIP-119: Fix missing self. prefix on stack reference in pseudocode",
    "user": {
      "login": "schjonhaug",
      "id": 84225,
      "node_id": "MDQ6VXNlcjg0MjI1",
      "avatar_url": "https://avatars.githubusercontent.com/u/84225?v=4",
